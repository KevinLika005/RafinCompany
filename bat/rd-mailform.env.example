## Core mail settings (always required)
MAIL_USE_SMTP=true
MAIL_RECIPIENT=
MAIL_FROM_EMAIL=

## SMTP settings (required when MAIL_USE_SMTP=true)
MAIL_SMTP_HOST=
MAIL_SMTP_PORT=587
MAIL_SMTP_USERNAME=
MAIL_SMTP_PASSWORD=
## Allowed values: tls, ssl, none
MAIL_SMTP_SECURE=tls

# Optional: on localhost/127.0.0.1, block real external delivery unless you explicitly allow it.
# Local SMTP catchers such as Mailpit or MailHog on 127.0.0.1:1025 are still allowed without this flag.
MAIL_ALLOW_LOCALHOST_LIVE_DELIVERY=false

# Optional: write safe request diagnostics to data/mail-debug.jsonl
MAIL_DEBUG=false

# Optional reCAPTCHA server-side verification endpoint support
RECAPTCHA_SECRET=
