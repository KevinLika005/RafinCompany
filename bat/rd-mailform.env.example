## Core mail settings (always required)
MAIL_USE_SMTP=true
MAIL_RECIPIENT=
MAIL_FROM_EMAIL=

## SMTP settings (required when MAIL_USE_SMTP=true unless fallback is enabled)
MAIL_SMTP_HOST=
MAIL_SMTP_PORT=587
MAIL_SMTP_USERNAME=
MAIL_SMTP_PASSWORD=
## Allowed values: tls, ssl, none
MAIL_SMTP_SECURE=tls

## Optional transport behavior
## When true and SMTP config is incomplete, allow PHPMailer default php mail() transport as fallback.
MAIL_ALLOW_PHP_MAIL_FALLBACK=false

## Optional anti-spam behavior
MAIL_DISABLE_ANTI_SPAM=false
MAIL_MIN_FORM_AGE_SECONDS=2
MAIL_MAX_FORM_AGE_SECONDS=86400
MAIL_RATE_LIMIT_MAX_PER_WINDOW=8
MAIL_RATE_LIMIT_WINDOW_SECONDS=3600
MAIL_RATE_LIMIT_MIN_SECONDS_BETWEEN=10

## Optional localhost guardrail:
## on localhost/127.0.0.1, block real external delivery unless explicitly allowed.
## Local SMTP catchers such as Mailpit or MailHog on 127.0.0.1:1025 are still allowed without this flag.
MAIL_ALLOW_LOCALHOST_LIVE_DELIVERY=false

## Optional: write safe request diagnostics to data/mail-debug.jsonl
MAIL_DEBUG=false

## Optional reCAPTCHA server-side verification endpoint support
RECAPTCHA_SECRET=

## --- Strict production mode (recommended) ---
## MAIL_USE_SMTP=true
## MAIL_ALLOW_PHP_MAIL_FALLBACK=false
## MAIL_DISABLE_ANTI_SPAM=false
## MAIL_MIN_FORM_AGE_SECONDS=2
## MAIL_MAX_FORM_AGE_SECONDS=86400
## MAIL_RATE_LIMIT_MAX_PER_WINDOW=8
## MAIL_RATE_LIMIT_WINDOW_SECONDS=3600
## MAIL_RATE_LIMIT_MIN_SECONDS_BETWEEN=10

