Options -Indexes
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  # Keep ACME/LetsEncrypt challenges accessible while protecting hidden paths.
  RewriteRule "(^|/)\.(?!well-known/)" - [F,L]
  # Block public access to local-only tooling folders if they are ever uploaded.
  RewriteRule "^(?:\.tmp-edge|\.tools|\.vendor|\.vscode)(?:/|$)" - [F,L,NC]
  # Only the active mail endpoints should be web-accessible under /bat.
  RewriteRule "^bat/(?:phpmailer|ReCaptcha)(?:/|$)" - [F,L,NC]
  RewriteRule "^bat/(?:index\.html|rd-search\.php)$" - [F,L,NC]
</IfModule>

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  Header always unset X-Powered-By
  Header merge Vary "Accept-Encoding"

  <FilesMatch "\.(?:html?|php)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  <FilesMatch "\.(?:css|js|mjs)$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>

  <FilesMatch "\.(?:png|jpe?g|gif|svg|webp|ico|woff2?|ttf|eot)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>

  <FilesMatch "\.(?:mp4)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType text/javascript "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType application/x-javascript "access plus 7 days"
  ExpiresByType image/jpeg "access plus 30 days"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/gif "access plus 30 days"
  ExpiresByType image/webp "access plus 30 days"
  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType image/x-icon "access plus 30 days"
  ExpiresByType video/mp4 "access plus 30 days"
  ExpiresByType font/woff2 "access plus 30 days"
  ExpiresByType font/woff "access plus 30 days"
  ExpiresByType application/font-woff "access plus 30 days"
  ExpiresByType font/ttf "access plus 30 days"
  ExpiresByType application/vnd.ms-fontobject "access plus 30 days"
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/plain text/html text/xml text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

<IfModule mod_authz_core.c>
  <FilesMatch "^(PLAN\.md|Final-Release-HardeningPlan\.md|SEO-Responsiveness-Plan\.md|Plani-Struktura\.txt|Rafin_Codex_Redesign_Brief\.docx|MAIL_TESTING\.md|rd-mailform\.env\.example|rd-mailform\.config\.json|rd-mailform\.tpl)$">
    Require all denied
  </FilesMatch>
  <FilesMatch "\.(?:map|jsonl|log)$">
    Require all denied
  </FilesMatch>
</IfModule>

<IfModule !mod_authz_core.c>
  <FilesMatch "^(PLAN\.md|Final-Release-HardeningPlan\.md|SEO-Responsiveness-Plan\.md|Plani-Struktura\.txt|Rafin_Codex_Redesign_Brief\.docx|MAIL_TESTING\.md|rd-mailform\.env\.example|rd-mailform\.config\.json|rd-mailform\.tpl)$">
    Order allow,deny
    Deny from all
  </FilesMatch>
  <FilesMatch "\.(?:map|jsonl|log)$">
    Order allow,deny
    Deny from all
  </FilesMatch>
</IfModule>
